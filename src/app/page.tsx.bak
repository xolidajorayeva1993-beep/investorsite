"use client";

import Link from "next/link";
import { useEffect, useState } from "react";
import type { AggregatedStats, FundraisingStatus } from "@/lib/types";

type HubData = {
  success: boolean;
  stats: AggregatedStats;
  fundraising: FundraisingStatus;
};

/* ═══ BIZNES KONSTANTALAR ═══ */
const CREATOR_PCT = 20;          // Yaratuvchi doim 20%
const INVESTOR_POOL_PCT = 80;    // Investorlarga 80%
const PRESETS = [5_000_000, 10_000_000, 25_000_000, 50_000_000, 100_000_000];

function fmtUzs(n: number): string {
  if (n >= 1_000_000_000) return (n / 1_000_000_000).toFixed(2) + " mlrd";
  if (n >= 1_000_000) return (n / 1_000_000).toFixed(1) + " mln";
  if (n >= 1_000) return (n / 1_000).toFixed(0) + " ming";
  return n.toLocaleString();
}
function fmtMoney(n: number): string {
  return n.toLocaleString("uz-UZ");
}

/* ═══ PIE CHART (SVG) ═══ */
function PieChart({
  creatorPct,
  investorPct,
  yourPct,
  size = 200,
}: {
  creatorPct: number;
  investorPct: number;
  yourPct: number;
  size?: number;
}) {
  const r = size / 2;
  const cx = r;
  const cy = r;
  const ir = r * 0.55; // donut inner radius

  function arc(startPct: number, endPct: number) {
    const s = (startPct / 100) * 360 - 90;
    const e = (endPct / 100) * 360 - 90;
    const sRad = (s * Math.PI) / 180;
    const eRad = (e * Math.PI) / 180;
    const large = endPct - startPct > 50 ? 1 : 0;
    return [
      `M ${cx + ir * Math.cos(sRad)} ${cy + ir * Math.sin(sRad)}`,
      `L ${cx + r * Math.cos(sRad)} ${cy + r * Math.sin(sRad)}`,
      `A ${r} ${r} 0 ${large} 1 ${cx + r * Math.cos(eRad)} ${cy + r * Math.sin(eRad)}`,
      `L ${cx + ir * Math.cos(eRad)} ${cy + ir * Math.sin(eRad)}`,
      `A ${ir} ${ir} 0 ${large} 0 ${cx + ir * Math.cos(sRad)} ${cy + ir * Math.sin(sRad)}`,
      "Z",
    ].join(" ");
  }

  const otherInvestorsPct = Math.max(0, investorPct - yourPct);
  const s1 = 0;
  const e1 = creatorPct;
  const s2 = e1;
  const e2 = e1 + otherInvestorsPct;
  const s3 = e2;
  const e3 = e2 + yourPct;

  return (
    <svg width={size} height={size} viewBox={`0 0 ${size} ${size}`}>
      {/* yaratuvchi */}
      {creatorPct > 0.3 && (
        <path d={arc(s1, e1)} fill="#BF5AF2" opacity={0.85} />
      )}
      {/* boshqa investorlar */}
      {otherInvestorsPct > 0.3 && (
        <path d={arc(s2, e2)} fill="#5856D6" opacity={0.7} />
      )}
      {/* siz */}
      {yourPct > 0.3 && (
        <path d={arc(s3, e3)} fill="#0071E3" />
      )}
      {/* center text */}
      <text x={cx} y={cy - 6} textAnchor="middle" fill="#1D1D1F" fontSize="22" fontWeight="700">
        {yourPct.toFixed(1)}%
      </text>
      <text x={cx} y={cy + 14} textAnchor="middle" fill="#86868B" fontSize="10">
        sizning ulush
      </text>
    </svg>
  );
}

export default function HomePage() {
  const [data, setData] = useState<HubData | null>(null);
  const [loading, setLoading] = useState(true);
  const [investAmount, setInvestAmount] = useState(10_000_000);
  const [activePreset, setActivePreset] = useState(10_000_000);

  useEffect(() => {
    fetch("/api/hub/stats")
      .then((r) => r.json())
      .then((d: HubData) => setData(d))
      .catch(() => {})
      .finally(() => setLoading(false));
  }, []);

  const stats = data?.stats;
  const fund = data?.fundraising;
  const totalRevenueUzs = stats?.totals.monthlyRevenueUzs ?? 0;
  const currentInvested = fund?.currentCapitalUzs ?? 0;  // hozirgi investorlar jami
  const investorCount = fund?.investorCount ?? 0;
  const targetCapital = fund?.targetCapitalUzs ?? 500_000_000;

  /* ═══ YANGI FORMULA ═══
     Toza daromad 2 ga bo'linadi:
       - 20% → yaratuvchi (doim)
       - 80% → investorlar fondi
     Investorlar fondi ichida har kimga proporsional:
       investor_ulushi = (uning_puli / jami_kiritilgan) × 80%
     Misol: 4 investor × 10M = 40M. Yangi investor 10M kiritsa → jami 50M
       yangi investor ulushi = (10M / 50M) × 80% = 16%
       oylik foydasi = toza_daromad × 16%
  */
  const newTotalInvested = currentInvested + investAmount;

  // Investorning 80% fond ichidagi ulushi
  const poolSharePct = newTotalInvested > 0
    ? (investAmount / newTotalInvested) * INVESTOR_POOL_PCT
    : 0;

  // Boshqa investorlarning umumiy ulushi
  const otherInvestorsPct = newTotalInvested > 0
    ? (currentInvested / newTotalInvested) * INVESTOR_POOL_PCT
    : 0;

  // Oylik va yillik foyda
  const monthlyProfit = totalRevenueUzs * (poolSharePct / 100);
  const yearlyProfit = monthlyProfit * 12;

  // Mavjud investorlarning har birining hozirgi oylik foydasi (siz kiritishdan oldin)
  const avgInvestmentPerInvestor = investorCount > 0
    ? currentInvested / investorCount
    : 0;
  const currentPerInvestorPct = currentInvested > 0 && investorCount > 0
    ? (avgInvestmentPerInvestor / currentInvested) * INVESTOR_POOL_PCT
    : 0;
  const currentPerInvestorProfit = totalRevenueUzs * (currentPerInvestorPct / 100);

  return (
    <div className="shell pt-4 pb-10">
      {/* ═══════════ NAV ═══════════ */}
      <header className="top-nav mt-2">
        <div className="brand">
          <span className="brand-dot" />
          Investorsite
        </div>
        <nav className="flex items-center gap-1 flex-wrap">
          <a href="#formula" className="nav-link">Formula</a>
          <a href="#portfolio" className="nav-link">Portfel</a>
          <a href="#calculator" className="nav-link">Kalkulyator</a>
          <a href="#how" className="nav-link">Jarayon</a>
          <Link href="/dashboard" className="nav-link">Kabinet</Link>
          <Link href="/become-investor" className="nav-cta">Investitsiya qilish</Link>
        </nav>
      </header>

      {/* ═══════════ HERO ═══════════ */}
      <section className="mt-16 md:mt-24 max-w-3xl">
        <span className="badge badge-gold">Cheklangan · 500 mln so&apos;m</span>
        <h1 className="mt-5 text-4xl sm:text-5xl md:text-[3.5rem] font-bold leading-[1.1] tracking-tight text-text">
          4 ta loyihaga{" "}
          <span className="text-accent">investitsiya</span>
          <br />
          qiling — har oy foyda oling
        </h1>
        <p className="mt-5 text-lg text-text-secondary leading-relaxed max-w-2xl">
          Toza daromadning <strong className="text-gold">80%</strong> investorlar o&apos;rtasida proporsional taqsimlanadi.
          Yaratuvchi doim <strong className="text-gold">20%</strong> oladi. Ulush — hozirgi investorlar soniga qarab hisoblanadi, 500 mln maqsadga emas.
        </p>
        <div className="mt-8 flex flex-wrap gap-3">
          <Link href="/become-investor" className="btn-primary">
            Investor bo&apos;lish
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"/></svg>
          </Link>
          <a href="#calculator" className="btn-secondary">
            Daromadni hisoblash
          </a>
        </div>
      </section>

      {/* ═══════════ LIVE STATS ═══════════ */}
      <section className="mt-16">
        <div className="grid grid-cols-2 md:grid-cols-4 gap-3">
          <div className="stat-box">
            <div className="stat-label">Faol platformalar</div>
            <div className="stat-value">
              <span className="text-accent">{stats?.totals.onlineProjects ?? "—"}</span>
              <span className="text-text-muted text-base font-normal"> / 4</span>
            </div>
          </div>
          <div className="stat-box">
            <div className="stat-label">Investorlar</div>
            <div className="stat-value">{investorCount}</div>
          </div>
          <div className="stat-box">
            <div className="stat-label">Oylik daromad</div>
            <div className="stat-value">
              <span className="text-accent">{fmtMoney(totalRevenueUzs)} </span>
              <span className="text-text-muted text-xs font-normal">so&apos;m</span>
            </div>
          </div>
          <div className="stat-box">
            <div className="stat-label">Kiritilgan invest.</div>
            <div className="stat-value">{fmtUzs(currentInvested)} <span className="text-text-muted text-xs font-normal">so&apos;m</span></div>
          </div>
        </div>

        {loading && (
          <p className="text-center text-sm text-text-muted mt-4 animate-pulse">
            Real-time ma&apos;lumotlar yuklanmoqda…
          </p>
        )}
      </section>

      {/* ═══════════ FORMULA TUSHUNTIRISH ═══════════ */}
      <section id="formula" className="mt-12">
        <span className="badge badge-section">Asosiy formula</span>
        <h2 className="text-2xl md:text-3xl font-bold tracking-tight">
          Foyda qanday taqsimlanadi?
        </h2>
        <p className="text-text-secondary mt-2 mb-8">
          Butun tizim 3 ta oddiy qoidaga asoslangan — shaffof va aniq.
        </p>

        <div className="grid md:grid-cols-3 gap-4">
          {/* Qoida 1 */}
          <div className="card-elevated text-center">
            <div className="w-14 h-14 mx-auto rounded-xl bg-gold/15 flex items-center justify-center text-2xl mb-4">
              👤
            </div>
            <div className="text-3xl font-bold text-gold mb-1">{CREATOR_PCT}%</div>
            <div className="text-sm font-bold text-text mb-2">Yaratuvchi ulushi</div>
            <p className="text-xs text-text-muted leading-relaxed">
              Loyihani yaratgan va boshqarayotgan shaxsga toza daromadning {CREATOR_PCT}% har doim tegadi.
              Bu ulush o&apos;zgarmaydi.
            </p>
          </div>

          {/* Qoida 2 */}
          <div className="card-elevated text-center border-accent/30">
            <div className="w-14 h-14 mx-auto rounded-xl bg-accent/15 flex items-center justify-center text-2xl mb-4">
              👥
            </div>
            <div className="text-3xl font-bold text-accent mb-1">{INVESTOR_POOL_PCT}%</div>
            <div className="text-sm font-bold text-text mb-2">Investorlar fondi</div>
            <p className="text-xs text-text-muted leading-relaxed">
              Qolgan {INVESTOR_POOL_PCT}% barcha investorlar o&apos;rtasida proporsional taqsimlanadi.
              Qancha pul kiritgan — shuncha ulush.
            </p>
          </div>

          {/* Qoida 3 */}
          <div className="card-elevated text-center">
            <div className="w-14 h-14 mx-auto rounded-xl bg-[#5856D6]/15 flex items-center justify-center text-2xl mb-4">
              🔄
            </div>
            <div className="text-sm font-bold text-text mb-2 mt-3">Dinamik ulush</div>
            <p className="text-xs text-text-muted leading-relaxed">
              Yangi investor qo&apos;shilsa — ulushlar avtomatik qayta hisoblanadi.
              500 mln yig&apos;ilgach — yangi investor qabul qilinmaydi.
            </p>
            <div className="mt-3 p-2 rounded-lg bg-bg border border-border text-xs text-text-muted">
              Maqsad: <strong className="text-text">{fmtMoney(targetCapital)}</strong> so&apos;m
            </div>
          </div>
        </div>

        {/* FORMULA VIZUAL */}
        <div className="card-elevated mt-6">
          <div className="text-xs font-bold text-text-muted uppercase tracking-wider mb-4">Real misolda formula</div>

          <div className="grid md:grid-cols-[1fr_auto_1fr] gap-6 items-start">
            {/* Chap: raqamlar */}
            <div className="space-y-3">
              <div className="flex justify-between items-center p-3 rounded-lg bg-bg border border-border">
                <span className="text-sm text-text-muted">Oylik toza daromad</span>
                <span className="font-mono font-bold text-accent">{fmtMoney(totalRevenueUzs)} so&apos;m</span>
              </div>
              <div className="flex justify-between items-center p-3 rounded-lg bg-bg border border-border">
                <span className="text-sm text-text-muted">→ Yaratuvchiga ({CREATOR_PCT}%)</span>
                <span className="font-mono font-bold text-gold">{fmtMoney(Math.round(totalRevenueUzs * CREATOR_PCT / 100))} so&apos;m</span>
              </div>
              <div className="flex justify-between items-center p-3 rounded-lg bg-bg border border-accent/30">
                <span className="text-sm text-text-muted">→ Investorlar fondiga ({INVESTOR_POOL_PCT}%)</span>
                <span className="font-mono font-bold text-accent">{fmtMoney(Math.round(totalRevenueUzs * INVESTOR_POOL_PCT / 100))} so&apos;m</span>
              </div>

              {investorCount > 0 && (
                <>
                  <div className="h-px bg-border my-1" />
                  <div className="flex justify-between items-center p-3 rounded-lg bg-bg border border-border">
                    <span className="text-sm text-text-muted">Hozirgi investorlar</span>
                    <span className="font-mono font-bold">{investorCount} kishi × {fmtMoney(Math.round(avgInvestmentPerInvestor))} so&apos;m</span>
                  </div>
                  <div className="flex justify-between items-center p-3 rounded-lg bg-accent/5 border border-accent/20">
                    <span className="text-sm text-text-muted">Har biriga oylik foyda</span>
                    <span className="font-mono font-bold text-accent">{fmtMoney(Math.round(currentPerInvestorProfit))} so&apos;m</span>
                  </div>
                </>
